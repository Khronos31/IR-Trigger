# IR-Trigger.yaml (V2 Architecture)

hubs:
  hub_study:
    name: "スタディのHub"
    tx:
      type: local_usb
      index: 1
    rx:
      type: local_usb
      index: 1
    local_receivers: [hub_study, hub_living]

  hub_living:
    name: "リビングのHub"
    tx:
      type: esphome
      entity_id: remote.atom_s3_living
    rx:
      type: webhook
      webhook_id: "living_hub_rx_12345"

devices:
  C_RT1:
    name: "C-RT1"
    template: "C-RT1"

  TV_Study:
    name: "スタディのテレビ"
    hub: "hub_study"
    template: "J-MX100RC"

  Recorder_Study:
    name: "スタディのレコーダー"
    hub: "hub_study"
    template: "RC-R2"

  HDMI_Study:
    name: "スタディのHDMI"
    hub: "hub_study"
    force_aeha_tx: true
    template: "UGREEN-55857"

  Light_Living:
    name: "リビングのライト"
    hub: "hub_living"
    template: "IR-A04HS"

global:
  repeat:
    - TV_Study
    - Recorder_Study
    - HDMI_Study
    - Light_Living
  remap:
    "NEC_56A939C6":
      - service: input_select.select_option
        target: { entity_id: input_select.ir_remote_mode }
        data: { option: "Recorder" }

state_machines:
  - name: "Study AV"
    mode_entity: input_select.ir_remote_mode
    modes:
      TV:
        bind:
          - source: C_RT1
            target: TV_Study
      Recorder:
        bind:
          - source: C_RT1
            target: Recorder_Study
